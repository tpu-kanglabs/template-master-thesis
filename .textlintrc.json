{
  "plugins": {
    "latex2e": true
  },
  "filters": {
    "comments": true,
    "allowlist": {
      "allow": []
    }
  },
  "rules": {
    "prh": {
      "rulePaths": [
        "./prh/punctuation.yml",
        "./prh/services.yml",
        "./prh/tech-terms.yml"
      ]
    },
    "preset-ja-technical-writing": {
      "ja-no-mixed-period": {
        "periodMark": "．"
      },
      "no-mix-dearu-desumasu": {
        "preferInHeader": "",
        "preferInBody": "である",
        "preferInList": "である",
        "strict": false
      }
    },
    "@textlint-ja/preset-ai-writing": true
  }
}
